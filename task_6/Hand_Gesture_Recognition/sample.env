# Configuration file for Hand Gesture Recognition Application
# Copy this to .env and adjust values as needed

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Hand Detection Configuration
# Detection confidence threshold (0.0 - 1.0)
DETECTION_CONFIDENCE=0.7
# Tracking confidence threshold (0.0 - 1.0)
TRACKING_CONFIDENCE=0.5

# Camera Configuration
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=30

# Gesture Recognition
# Pinch distance threshold for OK sign detection
PINCH_THRESHOLD=0.05
# Number of hands to detect simultaneously
MAX_HANDS=2

# File Upload
MAX_FILE_SIZE=16777216  # 16MB in bytes
UPLOAD_FOLDER=uploads
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,bmp

# Application Settings
LOG_LEVEL=INFO
SHOW_PERFORMANCE_METRICS=True
